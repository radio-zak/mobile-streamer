<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App does not track users -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No user data is collected -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required reason APIs used by this app and its dependencies -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>

		<!-- UserDefaults: used by Flutter engine and flutter_local_notifications
		     to persist notification settings and app preferences.
		     Reason CA92.1: access own app's user defaults -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>

		<!-- File timestamps: used by just_audio when caching audio sources
		     and by Flutter file I/O.
		     Reason C617.1: access timestamps of files created by the app -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>

		<!-- Disk space: used by just_audio before writing cached audio data.
		     Reason 85F4.1: only write data if sufficient space available -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>85F4.1</string>
			</array>
		</dict>

		<!-- System boot time: used by just_audio and networking layer
		     for measuring elapsed time and connection timeouts.
		     Reason 35F9.1: measure time elapsed on device -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>35F9.1</string>
			</array>
		</dict>

	</array>
</dict>
</plist>
